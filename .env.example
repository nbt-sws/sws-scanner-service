# sws-scanner-service environment variables
# Copy to .env.local and fill in the secrets for local development.

# Required
DATABASE_URL=postgres://sws:sws@localhost:5433/sws_scanner?sslmode=disable

# HTTP / gRPC ports
PORT=8088
GRPC_PORT=9090

# Logging
LOG_LEVEL=info

# Optional operational stores
REDIS_ADDR=localhost:6379
NATS_URL=nats://localhost:4222

# Firebase (required for Firestore / Storage features)
FIREBASE_SERVICE_ACCOUNT_B64=
FIREBASE_STORAGE_BUCKET=

# External AI / vision APIs
ANTHROPIC_API_KEY=
GOOGLE_VISION_API_KEY=

# eBay (required for real pricing)
EBAY_APP_ID=
EBAY_CERT_ID=

# Security / behavior
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_EMAILS=
AUCTION_REQUIRE_KYC=false
CRON_SECRET=

# Temporary mock auth for pre-vault/user prod testing.
# When enabled and MOCK_AUTH_KEY is set, requests must include header X-Mock-Auth-Key.
MOCK_AUTH_ENABLED=false
MOCK_USER_ID=
MOCK_USER_EMAIL=
MOCK_USER_ADMIN=false
MOCK_AUTH_KEY=
